<section class="promo-bar" data-animate>
  <div class="container promo-bar-inner">
    <div class="promo-bar-content">
      {% if section.settings.eyebrow != blank %}
        <span class="promo-bar-eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      <h3 class="promo-bar-title">{{ section.settings.title }}</h3>
      {% if section.settings.description != blank %}
        <p class="promo-bar-text">{{ section.settings.description }}</p>
      {% endif %}
    </div>
    <div class="promo-bar-right">
      {% if section.settings.show_countdown and section.settings.countdown_date != blank %}
        <div class="promo-countdown" data-countdown="{{ section.settings.countdown_date }}">
          <div class="countdown-unit">
            <span class="countdown-number" data-days>00</span>
            <span class="countdown-label">Days</span>
          </div>
          <div class="countdown-separator">:</div>
          <div class="countdown-unit">
            <span class="countdown-number" data-hours>00</span>
            <span class="countdown-label">Hours</span>
          </div>
          <div class="countdown-separator">:</div>
          <div class="countdown-unit">
            <span class="countdown-number" data-minutes>00</span>
            <span class="countdown-label">Min</span>
          </div>
          <div class="countdown-separator">:</div>
          <div class="countdown-unit">
            <span class="countdown-number" data-seconds>00</span>
            <span class="countdown-label">Sec</span>
          </div>
        </div>
      {% endif %}
      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_url }}" class="btn btn-white btn-lg">{{ section.settings.button_text }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Promo Bar",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Limited Time Offer"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Save $200 on Any Mattress"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Use code SLEEP200 at checkout. Offer ends soon!"
    },
    {
      "type": "checkbox",
      "id": "show_countdown",
      "label": "Show countdown timer",
      "default": true
    },
    {
      "type": "text",
      "id": "countdown_date",
      "label": "Countdown end date (YYYY-MM-DD)",
      "default": "2026-04-01"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop the Sale"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Promo Bar"
    }
  ]
}
{% endschema %}
