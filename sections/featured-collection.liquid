<section class="featured-collection section-padding">
  <div class="container">
    <div class="section-header">
      {% if section.settings.subtitle != blank %}
        <p class="section-subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
      <h2 class="section-title">{{ section.settings.title }}</h2>
    </div>

    <div class="product-grid">
      {% for product in collections[section.settings.collection].products limit: section.settings.products_to_show %}
        {% render 'product-card', product: product %}
      {% else %}
        {% for i in (1..3) %}
          <div class="product-card placeholder-card">
            <div class="product-card-image placeholder-image">
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
            <div class="product-card-info">
              <h3 class="product-card-title">Sample Mattress {{ i }}</h3>
              <p class="product-card-price">From $799</p>
              <a href="#" class="btn btn-secondary">View Details</a>
            </div>
          </div>
        {% endfor %}
      {% endfor %}
    </div>

    {% if section.settings.show_view_all %}
      <div class="section-footer">
        <a href="{{ collections[section.settings.collection].url }}" class="btn btn-outline">
          View All Mattresses
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Our Collection"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Find Your Perfect Mattress"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View All' button",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
