<section class="comparison-table section-padding" data-animate>
  <div class="container">
    <div class="section-header">
      {% if section.settings.subtitle != blank %}
        <p class="section-subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
      <h2 class="section-title">{{ section.settings.title }}</h2>
      {% if section.settings.description != blank %}
        <p class="section-description">{{ section.settings.description }}</p>
      {% endif %}
    </div>

    <div class="comparison-wrapper">
      <table class="comparison-grid">
        <thead>
          <tr>
            <th class="comparison-feature-header">Features</th>
            {% for block in section.blocks %}
              {% if block.type == 'mattress' %}
                <th class="comparison-product-header" {{ block.shopify_attributes }}>
                  {% if block.settings.badge != blank %}
                    <span class="comparison-badge">{{ block.settings.badge }}</span>
                  {% endif %}
                  <span class="comparison-product-name">{{ block.settings.name }}</span>
                  <span class="comparison-product-price">{{ block.settings.price }}</span>
                </th>
              {% endif %}
            {% endfor %}
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="comparison-feature-label">Firmness</td>
            {% for block in section.blocks %}
              {% if block.type == 'mattress' %}
                <td {{ block.shopify_attributes }}>
                  <div class="firmness-scale">
                    <div class="firmness-bar">
                      <div class="firmness-fill" style="width: {{ block.settings.firmness | times: 10 }}%"></div>
                    </div>
                    <span class="firmness-label">{{ block.settings.firmness_label }}</span>
                  </div>
                </td>
              {% endif %}
            {% endfor %}
          </tr>
          <tr>
            <td class="comparison-feature-label">Type</td>
            {% for block in section.blocks %}
              {% if block.type == 'mattress' %}
                <td {{ block.shopify_attributes }}>{{ block.settings.type }}</td>
              {% endif %}
            {% endfor %}
          </tr>
          <tr>
            <td class="comparison-feature-label">Cooling</td>
            {% for block in section.blocks %}
              {% if block.type == 'mattress' %}
                <td {{ block.shopify_attributes }}>
                  {% if block.settings.cooling %}
                    <span class="comparison-check">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="3"><path d="M20 6L9 17l-5-5"></path></svg>
                    </span>
                  {% else %}
                    <span class="comparison-cross">—</span>
                  {% endif %}
                </td>
              {% endif %}
            {% endfor %}
          </tr>
          <tr>
            <td class="comparison-feature-label">Motion Isolation</td>
            {% for block in section.blocks %}
              {% if block.type == 'mattress' %}
                <td {{ block.shopify_attributes }}>
                  {% if block.settings.motion_isolation %}
                    <span class="comparison-check">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="3"><path d="M20 6L9 17l-5-5"></path></svg>
                    </span>
                  {% else %}
                    <span class="comparison-cross">—</span>
                  {% endif %}
                </td>
              {% endif %}
            {% endfor %}
          </tr>
          <tr>
            <td class="comparison-feature-label">Edge Support</td>
            {% for block in section.blocks %}
              {% if block.type == 'mattress' %}
                <td {{ block.shopify_attributes }}>
                  {% if block.settings.edge_support %}
                    <span class="comparison-check">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="3"><path d="M20 6L9 17l-5-5"></path></svg>
                    </span>
                  {% else %}
                    <span class="comparison-cross">—</span>
                  {% endif %}
                </td>
              {% endif %}
            {% endfor %}
          </tr>
          <tr>
            <td class="comparison-feature-label">Best For</td>
            {% for block in section.blocks %}
              {% if block.type == 'mattress' %}
                <td {{ block.shopify_attributes }}>{{ block.settings.best_for }}</td>
              {% endif %}
            {% endfor %}
          </tr>
          <tr class="comparison-cta-row">
            <td></td>
            {% for block in section.blocks %}
              {% if block.type == 'mattress' %}
                <td {{ block.shopify_attributes }}>
                  {% if block.settings.product_url != blank %}
                    <a href="{{ block.settings.product_url }}" class="btn btn-primary btn-sm">Shop Now</a>
                  {% endif %}
                </td>
              {% endif %}
            {% endfor %}
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Comparison Table",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Compare"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Find Your Perfect Match"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Not sure which mattress is right for you? Compare our top models side by side."
    }
  ],
  "blocks": [
    {
      "type": "mattress",
      "name": "Mattress",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Mattress name",
          "default": "CloudRest Hybrid"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Starting price",
          "default": "From $899"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge (e.g. Best Seller)"
        },
        {
          "type": "range",
          "id": "firmness",
          "label": "Firmness (1-10)",
          "min": 1,
          "max": 10,
          "default": 6
        },
        {
          "type": "text",
          "id": "firmness_label",
          "label": "Firmness label",
          "default": "Medium"
        },
        {
          "type": "text",
          "id": "type",
          "label": "Mattress type",
          "default": "Hybrid"
        },
        {
          "type": "checkbox",
          "id": "cooling",
          "label": "Has cooling",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "motion_isolation",
          "label": "Has motion isolation",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "edge_support",
          "label": "Has edge support",
          "default": true
        },
        {
          "type": "text",
          "id": "best_for",
          "label": "Best for",
          "default": "All sleep positions"
        },
        {
          "type": "url",
          "id": "product_url",
          "label": "Product link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Comparison Table",
      "blocks": [
        {
          "type": "mattress",
          "settings": {
            "name": "CloudRest Hybrid",
            "price": "From $899",
            "badge": "Best Seller",
            "firmness": 6,
            "firmness_label": "Medium",
            "type": "Hybrid",
            "cooling": true,
            "motion_isolation": true,
            "edge_support": true,
            "best_for": "All sleep positions"
          }
        },
        {
          "type": "mattress",
          "settings": {
            "name": "DreamFoam Original",
            "price": "From $699",
            "firmness": 5,
            "firmness_label": "Medium-Soft",
            "type": "Memory Foam",
            "cooling": true,
            "motion_isolation": true,
            "edge_support": false,
            "best_for": "Side sleepers"
          }
        },
        {
          "type": "mattress",
          "settings": {
            "name": "OrthoSupport Firm",
            "price": "From $999",
            "firmness": 8,
            "firmness_label": "Firm",
            "type": "Innerspring Hybrid",
            "cooling": true,
            "motion_isolation": false,
            "edge_support": true,
            "best_for": "Back & stomach sleepers"
          }
        }
      ]
    }
  ]
}
{% endschema %}
