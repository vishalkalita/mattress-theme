<section class="quiz-banner" data-animate>
  <div class="quiz-banner-bg" {% if section.settings.image != blank %}style="background-image: url('{{ section.settings.image | image_url: width: 1920 }}')"{% endif %}>
    <div class="quiz-banner-overlay"></div>
    <div class="container quiz-banner-content">
      <div class="quiz-banner-icon">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
          <line x1="12" y1="17" x2="12.01" y2="17"></line>
        </svg>
      </div>
      <h2 class="quiz-banner-title">{{ section.settings.title }}</h2>
      <p class="quiz-banner-text">{{ section.settings.description }}</p>
      <div class="quiz-banner-steps">
        <div class="quiz-step">
          <span class="quiz-step-num">1</span>
          <span class="quiz-step-text">{{ section.settings.step_1 }}</span>
        </div>
        <div class="quiz-step-arrow">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </div>
        <div class="quiz-step">
          <span class="quiz-step-num">2</span>
          <span class="quiz-step-text">{{ section.settings.step_2 }}</span>
        </div>
        <div class="quiz-step-arrow">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </div>
        <div class="quiz-step">
          <span class="quiz-step-num">3</span>
          <span class="quiz-step-text">{{ section.settings.step_3 }}</span>
        </div>
      </div>
      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_url }}" class="btn btn-accent btn-lg">
          {{ section.settings.button_text }}
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-left:8px"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Quiz Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Not Sure Which Mattress Is Right for You?"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Take our 2-minute sleep quiz and we'll recommend the perfect mattress based on your sleep style, body type, and preferences."
    },
    {
      "type": "text",
      "id": "step_1",
      "label": "Step 1 text",
      "default": "Answer a few questions"
    },
    {
      "type": "text",
      "id": "step_2",
      "label": "Step 2 text",
      "default": "Get your match"
    },
    {
      "type": "text",
      "id": "step_3",
      "label": "Step 3 text",
      "default": "Sleep better tonight"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Take the Sleep Quiz"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Quiz Banner"
    }
  ]
}
{% endschema %}
