<section class="press-logos" data-animate>
  <div class="container">
    {% if section.settings.title != blank %}
      <p class="press-logos-title">{{ section.settings.title }}</p>
    {% endif %}
    <div class="press-logos-track">
      {% for block in section.blocks %}
        <div class="press-logo-item" {{ block.shopify_attributes }}>
          {% if block.settings.logo != blank %}
            <img
              src="{{ block.settings.logo | image_url: width: 180 }}"
              alt="{{ block.settings.name | escape }}"
              width="180"
              height="60"
              loading="lazy"
            >
          {% else %}
            <span class="press-logo-placeholder">{{ block.settings.name }}</span>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Press Logos",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "As Featured In"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Publication name",
          "default": "Forbes"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Press Logos",
      "blocks": [
        { "type": "logo", "settings": { "name": "Forbes" } },
        { "type": "logo", "settings": { "name": "Good Housekeeping" } },
        { "type": "logo", "settings": { "name": "Sleep Foundation" } },
        { "type": "logo", "settings": { "name": "Wirecutter" } },
        { "type": "logo", "settings": { "name": "Business Insider" } }
      ]
    }
  ]
}
{% endschema %}
